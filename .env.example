# ============================================
# .env.example — скопируйте в .env и заполните
# ============================================

# ──────────────────────────────────────
# Supabase (фронтенд + backend/lib)
# ──────────────────────────────────────

# URL вашего Supabase проекта
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon key (публичный, используется в браузере)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────
# Supabase (server-side — НЕ передавать на фронтенд!)
# ──────────────────────────────────────

# Service role key (только для Express-сервера)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────
# ЮKassa (только для Express-сервера)
# ──────────────────────────────────────

# ID магазина из личного кабинета ЮKassa
YOKASSA_SHOP_ID=123456

# Секретный ключ API из личного кабинета ЮKassa
YOKASSA_SECRET_KEY=test_xxxxxxxxxxx

# Разрешённые IP-адреса ЮKassa (через запятую)
# Актуальный список: https://yookassa.ru/developers/using-api/webhooks
# В разработке оставьте пустым
YOKASSA_WEBHOOK_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,77.75.156.11,77.75.156.35

# ──────────────────────────────────────
# Приложение
# ──────────────────────────────────────

# URL фронтенда в браузере (редирект после оплаты ЮKassa и т.п.).
# Локально: http://localhost:5173
# На Railway (сервер): https://ВАШ-ПРОЕКТ.vercel.app — не домен Railway!
APP_URL=http://localhost:5173

# CORS: с каких сайтов браузер может вызывать API на Railway.
# На Railway задайте: https://ВАШ-ПРОЕКТ.vercel.app,http://localhost:5173
# ALLOWED_ORIGINS=https://example.vercel.app,http://localhost:5173

# Порт Express-сервера
PORT=3001

# Режим: development | production
NODE_ENV=development

# ──────────────────────────────────────
# Яндекс Cloud Monitoring — метрики (backend на Railway)
# ──────────────────────────────────────
# Sentry в этом проекте не используется; ошибки и бизнес-события уходят в Monitoring.
# Настройка: docs/monitoring.md
#
# Сервисный аккаунт с ролью monitoring.writer + статический ключ в консоли Yandex Cloud.
# PEM приватного ключа в одну строку: между строками PEM подставьте \n (или мультистрока в Railway).
YC_FOLDER_ID=
YC_SERVICE_ACCOUNT_ID=
YC_ACCESS_KEY_ID=
YC_PRIVATE_KEY=
# PEM целиком в Base64 (если в Railway «ломаются» переносы строк в YC_PRIVATE_KEY)
# YC_PRIVATE_KEY_BASE64=
YC_DEPLOY_ENV=production
# 1 — логировать успешный ответ API при записи метрик (отладка)
# YC_MONITORING_DEBUG=1
# Отдельный секрет для POST /api/monitoring/self-test (иначе используется MONITORING_INGEST_SECRET)
# YC_SELF_TEST_SECRET=

# Приём ошибок фронта: POST /api/monitoring/ingest — общий секрет с VITE_MONITORING_INGEST_SECRET (опционально)
MONITORING_INGEST_SECRET=

# Подписка для роли business всегда обязательна в коде.
# Для локальных тестов оплаты без ЮKassa: PAYMENTS_ENABLED=false (см. server / yookassa.js)
PAYMENTS_ENABLED=true
# YOOKASSA_SHOP_ID=
# YOKASSA_SECRET_KEY=
# YOKASSA_WEBHOOK_SECRET=
# YOKASSA_WEBHOOK_IPS=

# ──────────────────────────────────────
# URL Express-сервера (для фронтенда)
# ──────────────────────────────────────
# Локально: http://localhost:3001 (как у PORT)
# Вариант A — прямой вызов Railway из браузера (нужен ALLOWED_ORIGINS на Railway):
#   VITE_SERVER_URL=https://ВАШ-СЕРВИС.up.railway.app
# Вариант B — рекомендуется на Vercel: прокси /api/* (папка api/ в репо).
#   Удалите VITE_SERVER_URL из Vercel (или оставьте пустым).
#   В Vercel добавьте ТОЛЬКО для сервера (без префикса VITE_): см. ниже AUTH_API_UPSTREAM

# ──────────────────────────────────────
# Только Vercel (Serverless, не попадает в бандл фронта)
# ──────────────────────────────────────
# AUTH_API_UPSTREAM=https://ВАШ-СЕРВИС.up.railway.app
# Дублирующее имя (если удобнее): RAILWAY_API_URL
#
# Vercel → Settings → General → Root Directory:
#   пусто = корень репозитория (деплоятся api/ в корне и vercel.json из корня);
#   «frontend» = только папка frontend (деплоится frontend/api/ из этого репо).

VITE_SERVER_URL=http://localhost:3001

# ──────────────────────────────────────
# Опционально: Telegram уведомления
# ──────────────────────────────────────
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# ──────────────────────────────────────
# Яндекс Monitoring — фронт (Vercel): только ingest в бэкенд; ключи SA только на Railway
# ──────────────────────────────────────
# true — отправлять ошибки на /api/monitoring/ingest → метрика saas.frontend.error в Яндекс Monitoring
VITE_YC_MONITORING_INGEST=false
VITE_MONITORING_INGEST_SECRET=

# Яндекс Метрика (номер счётчика, только цифры)
VITE_YANDEX_METRIKA_ID=

# ──────────────────────────────────────
# Опционально: Auth API rate-limit
# ──────────────────────────────────────
# VITE_USE_AUTH_API=true
