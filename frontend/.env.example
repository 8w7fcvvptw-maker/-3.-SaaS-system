# Скопируйте в .env и заполните. Файл .env не коммитьте.
#
# Supabase: Dashboard → Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   anon public  → VITE_SUPABASE_ANON_KEY (не путать с service_role — его во фронт не кладут)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CORS для server/auth-api (порт 3001): только перечисленные origin (без *). Через Vite proxy / тот же домен — часто не нужно.
# В проде добавьте URL фронта: ALLOWED_ORIGINS=https://ваш-домен.ru
# ALLOWED_ORIGINS=

# Вход/регистрация через локальный API с rate limit (корень репо: npm run dev).
# false — напрямую в Supabase Auth, без лимита в приложении
# VITE_USE_AUTH_API=false

# Monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_APP_VERSION=1.0.0

# Яндекс Метрика (ID счётчика, только цифры)
VITE_YANDEX_METRIKA_ID=

# Интеграционные тесты (vitest): npm run test — опционально
# VITE_TEST_USER_EMAIL=
# VITE_TEST_USER_PASSWORD=

# Playwright E2E: npm run test:e2e
E2E_LOGIN_EMAIL=
E2E_LOGIN_PASSWORD=
# Опционально: service role только для e2e/global-setup.ts (активная подписка для business).
# Можно задать в корне репозитория (.env) — global-setup подхватит. Без пробела после = . Не коммитить.
# SUPABASE_SERVICE_ROLE_KEY=
